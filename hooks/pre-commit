#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

LOG_FILE=$(mktemp)

echo -e "${BLUE}▶ Starting Quality Checks...${NC}"

# 1. Run lint-staged (Formatting and Linting)
echo -ne "  [1/2] Formatting & Linting (lint-staged)... "
npx lint-staged > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- LINT/FORMAT ERROR LOG ---${NC}"
    cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

# 2. Unit Tests (Vitest)
echo -ne "  [2/2] Unit Tests (Vitest)... "
npx vitest run --reporter=verbose > "$LOG_FILE" 2>&1
if [ $? -eq 0 ]; then
    echo -e "${GREEN}PASSED${NC}"
else
    echo -e "${RED}FAILED${NC}"
    echo -e "${YELLOW}--- TEST FAILURE LOG ---${NC}"
    cat "$LOG_FILE"
    rm -f "$LOG_FILE"
    exit 1
fi

rm -f "$LOG_FILE"
echo -e "${GREEN}✔ All checks passed!${NC}"
exit 0